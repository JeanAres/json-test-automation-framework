            "descricao": "Screenshot da tela de login"
        },
        {
            "acao": "fill",
            "seletor": "[name='userName']",
            "valor": "{{ADMIN_USER}}",
            "descricao": "Preencher usuário"
        },
        {
            "acao": "fill",
            "seletor": "[name='password']",
            "valor": "{{ADMIN_PASS}}",
            "descricao": "Preencher senha"
