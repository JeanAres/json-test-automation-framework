        {
            "acao": "executar_script",
            "script": "window.itensASC = [...document.querySelectorAll('tbody tr')].map(row => row.cells[0]?.textContent.trim()).filter(t => t); window.itensASC;",
            "variavel": "itens_asc",
            "descricao": "Captura ASC inicial"
        },
        {
            "acao": "screenshot",
            "nome": "05_order_asc",
            "descricao": "Screenshot da coluna 'Nome' em ASC"
