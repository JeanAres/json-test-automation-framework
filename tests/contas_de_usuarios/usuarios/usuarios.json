{
    "nome": "Teste Completo - Login + Testar todas as funcionabilidades na sub-categoria 'Usuários'",
    "descricao": "Faz login automaticamente e depois testa todos os funcionamentos dísponiveis na sub-categoria 'Usuários'",
    "configuracoes":{
        "timeout":20000,
        "slow_motion":1000,
        "largura":1366,
        "altura":768,
        "idioma":"pt-BR"
    },
