        },
        {
            "acao": "wait",
            "tempo": 1500
        },
        {
            "acao": "executar_script",
            "script": "window.itensDESC = [...document.querySelectorAll('tbody tr')].map(row => row.cells[0]?.textContent.trim()).filter(t => t); window.itensDESC;",
            "variavel": "itens_desc",
            "descricao": "Captura DESC"
