            "descricao": "Screenshot da coluna 'Nome' em DESC"
          },
          {
            "acao": "wait",
            "tempo": 1500
          },
          {
            "acao": "executar_script",
            "script": "window.itensDESC = [...document.querySelectorAll('tbody tr')].map(row => row.cells[0]?.textContent.trim()).filter(t => t); window.itensDESC;",
            "variavel": "itens_desc",
            "descricao": "Captura DESC"
          },
          {
            "acao": "click",
            "seletor": "button:has-text('Nome')",
            "descricao": "Clique 2 - Volta ASC"
          },
          {
            "acao": "wait",
            "tempo": 1500
          },
          {
            "acao": "executar_script",
            "script": "const itensASC2 = [...document.querySelectorAll('tbody tr')].map(row => row.cells[0]?.textContent.trim()).filter(t => t); const voltouParaASC = JSON.stringify(window.itensASC) === JSON.stringify(itensASC2); const resultado = { totalASC: window.itensASC.length, totalDESC: window.itensDESC.length, primeiros5ASC: window.itensASC.slice(0, 5), primeiros5DESC: window.itensDESC.slice(0, 5), ultimos5DESC: window.itensDESC.slice(-5), match: voltouParaASC }; console.log('Voltou para ASC?', voltouParaASC); resultado;",
            "variavel": "resultado_completo",
            "descricao": "Valida se voltou para ASC inicial"
          },
